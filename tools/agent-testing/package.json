{
  "name": "agent-testing",
  "version": "1.0.0",
  "private": true,
  "description": "Framework de pruebas para agentes y skills de OpenCode",
  "scripts": {
    "test": "node run.mjs",
    "test:summary": "node run.mjs 2>&1 | Select-String -Pattern 'PASS|FAIL|SKIP|Summary|Total'",
