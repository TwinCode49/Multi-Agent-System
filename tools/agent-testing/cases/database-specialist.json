{
  "agent": "database-specialist",
  "type": "secondary",
  "checks": {
    "frontmatter": {
      "description": "starts with TRIGGER KEYWORDS:",
      "mode": "subagent",
      "permission": { "edit": "allow", "bash": "allow" }
    },
    "keywords": ["database", "SQL", "query", "schema", "migration", "ORM", "PostgreSQL", "index"],
    "sections": ["Core Responsibilities", "Behavior Rules", "Response Format", "Constraints", "Handoff Protocol"],
    "contains": ["EXPLAIN ANALYZE", "parameterized queries", "rollback", "N+1"],
    "readOnly": false
  }
}
