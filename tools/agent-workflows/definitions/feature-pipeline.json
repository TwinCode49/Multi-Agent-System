{
  "name": "feature-pipeline",
  "version": "1.0",
  "description": "Implement a feature: build → test → document",
  "trigger_keywords": [
    "feature",
    "implement",
    "new functionality"
  ],
  "steps": [
    {
      "id": "database-specialist_build",
      "agent": "database-specialist",
      "skill": "database",
      "prompt": "Implement the feature. Output code and changes.",
      "output_key": "database-specialist_build",
      "depends_on": []
    },
    {
      "id": "test-engineer_test",
      "agent": "test-engineer",
      "skill": "testing",
      "prompt": "Write tests for the implementation created in the previous step.",
      "output_key": "test-engineer_test",
      "depends_on": [
        "database-specialist_build"
      ]
    },
    {
      "id": "doc-agent_docs",
      "agent": "doc-agent",
      "skill": "documentation",
      "prompt": "Document the new feature: update API docs, add changelog entry.",
      "output_key": "doc-agent_docs",
      "depends_on": [
        "database-specialist_build"
      ]
    }
  ],
  "format": "executor-json",
  "platform": "opencode",
  "agent_skills": {
    "code-reviewer": [],
    "database-specialist": [
      "database"
    ],
    "devops-agent": [
      "containerization"
    ],
    "doc-agent": [
      "documentation"
    ],
    "orchestrator": [],
    "perf-engineer": [
      "backend",
      "database"
    ],
    "security-reviewer": [
      "backend",
      "containerization"
    ],
    "test-engineer": [
      "testing"
    ],
    "ui-specialist": [
      "frontend"
    ]
  }
}