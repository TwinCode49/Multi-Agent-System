{
  "name": "docs-generation",
  "version": "1.0",
  "description": "Analyze code and generate documentation",
  "trigger_keywords": [
    "docs",
    "documentation",
    "generate docs"
  ],
  "steps": [
    {
      "id": "database-specialist_inventory",
      "agent": "database-specialist",
      "skill": "database",
      "prompt": "Analyze the codebase and produce an inventory of APIs, components, and configurations.",
      "output_key": "database-specialist_inventory",
      "depends_on": []
    },
    {
      "id": "doc-agent_docs",
      "agent": "doc-agent",
      "skill": "documentation",
      "prompt": "Generate documentation based on the code inventory.",
      "output_key": "doc-agent_docs",
      "depends_on": [
        "database-specialist_inventory"
      ]
    }
  ],
  "format": "executor-json",
  "platform": "opencode",
  "agent_skills": {
    "code-reviewer": [],
    "database-specialist": [
      "database"
    ],
    "devops-agent": [
      "containerization"
    ],
    "doc-agent": [
      "documentation"
    ],
    "orchestrator": [],
    "perf-engineer": [
      "backend",
      "database"
    ],
    "security-reviewer": [
      "backend",
      "containerization"
    ],
    "test-engineer": [
      "testing"
    ],
    "ui-specialist": [
      "frontend"
    ]
  }
}